    "chalk": "^5.3.0",
    "esbuild": "^0.25.12",
    "ink": "^5.2.1",
    "marked": "^15.0.12",
    "react": "^18.3.1",
    "string-width": "^7.2.0",
    "vscode-jsonrpc": "^9.0.1",
